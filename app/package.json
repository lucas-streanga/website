{
    "name": "app",
    "type": "module",
    "version": "0.0.1",
    "engines": {
        "node": ">=22.12.0"
    },
    "scripts": {
        "predev": "node sync-luna-grammar.mjs",
        "dev": "rm -f .astro/dev.json && astro dev",
        "prebuild": "node sync-luna-grammar.mjs",
        "build": "astro build",
        "preview": "astro preview",
        "format": "prettier --write .",
        "format:watch": "chokidar \"src/**/*.{astro,ts,js,css}\" \"*.mjs\" \"tsconfig.json\" -c \"prettier --write {path}\" --polling",
        "audit": "lighthouse http://localhost:4321 --chrome-flags=\"--headless=new --no-sandbox --disable-dev-shm-usage --disable-gpu\" --output html --output-path ./lighthouse-report.html"
    },
    "dependencies": {
        "@astrojs/mdx": "^7.0.0",
        "@astrojs/rss": "^4.0.19",
        "@astrojs/sitemap": "^3.7.3",
        "@fontsource-variable/fraunces": "^5.2.9",
        "@fontsource-variable/inter": "^5.2.8",
        "astro": "^7.0.3"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.9",
        "@astrojs/markdown-remark": "^7.2.0",
        "chokidar-cli": "^3.0.0",
        "lighthouse": "^13.4.0",
        "prettier": "^3.9.5",
        "prettier-plugin-astro": "^0.14.1",
        "shiki": "^4.3.1",
        "typescript": "^6.0.3"
    }
}
