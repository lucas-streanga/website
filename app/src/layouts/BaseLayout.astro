---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { Font } from "astro:assets";
import Navbar from "../components/Navbar.astro";
interface Props {
    title?: string;
    description?: string;
    image?: string; // og:image — relative path or absolute URL; override per post
    type?: "website" | "article"; // og:type — "article" for blog posts
}
const {
    title = "streanga.com",
    description = "Personal site of Lucas — developer & writer.",
    image = "/og-default.png",
    type = "website",
} = Astro.props;
// Absolute URLs for canonical + social tags (requires `site` in astro.config.mjs).
// new URL(x, base): relative paths resolve against the site, absolute URLs pass
// through unchanged — so per-post overrides can be either.
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);
const SITE_NAME = "streanga.com";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <Font cssVariable="--font-inter" preload />
        <Font cssVariable="--font-literata" preload />
        <!-- Inline so it runs before first paint (no flash). Only an EXPLICIT
         choice is written; otherwise data-theme + inline color-scheme are cleared
         so CSS `color-scheme: light dark` follows the OS. color-scheme is pinned
         inline so the right scheme applies before the external stylesheet loads.
         On view transitions we theme the INCOMING document in astro:before-swap
         (before it paints) so navigation never flashes the OS theme. -->
        <script is:inline>
            (function () {
                function choice() {
                    try {
                        var v = localStorage.getItem("theme");
                        return v === "dark" || v === "light" ? v : null;
                    } catch (_) {
                        return null;
                    }
                }
                function apply(root) {
                    var c = choice();
                    if (c) {
                        root.dataset.theme = c;
                        root.style.colorScheme = c;
                    } else {
                        root.removeAttribute("data-theme");
                        root.style.removeProperty("color-scheme");
                    }
                }
                apply(document.documentElement);
                document.addEventListener("astro:before-swap", function (e) {
                    apply(e.newDocument.documentElement);
                });
            })();
        </script>
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />
        <!-- Favicons: the SVG covers modern browsers; add PNG/ICO to /public for broader coverage. -->
        <!-- ?v=2 busts browsers' aggressive favicon cache; bump it whenever the icon art changes. -->
        <link rel="icon" href="/favicon.svg?v=2" type="image/svg+xml" />
        <link rel="icon" href="/favicon.ico?v=2" sizes="32x32" />
        <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
        <!-- Open Graph (Slack, Discord, iMessage, Facebook, LinkedIn, …) -->
        <meta property="og:type" content={type} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:image" content={ogImageURL} />
        <meta property="og:image:alt" content={title} />
        <meta property="og:site_name" content={SITE_NAME} />
        <meta property="og:locale" content="en_US" />
        <!-- Twitter / X (falls back to og: for anything omitted) -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageURL} />
        <ClientRouter />
    </head>
    <body>
        <a href="#main" class="sr-only">Skip to content</a>
        <Navbar />
        <slot />
    </body>
</html>
