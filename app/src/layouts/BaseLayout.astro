---
// BaseLayout.astro — the HTML shell every page wraps in.
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
    title?: string;
    description?: string;
}

const {
    title = "streanga.com",
    description = "Lucas Streanga personal website.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <ClientRouter />
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description} />
        <title>{title}</title>

        <script is:inline>
            function applyTheme() {
                try {
                    var saved = localStorage.getItem("theme");
                    var prefersDark = window.matchMedia(
                        "(prefers-color-scheme: dark)",
                    ).matches;
                    document.documentElement.dataset.theme =
                        saved || (prefersDark ? "dark" : "light");
                } catch (_) {
                    document.documentElement.dataset.theme = "light";
                }
            }
            applyTheme(); // initial load / refresh
            document.addEventListener("astro:after-swap", applyTheme); // re-apply after each navigation
        </script>
    </head>

    <body>
        <a href="#main" class="sr-only">Skip to content</a>
        <Navbar />
        <slot />
    </body>
</html>
