---
import BaseLayout from "./BaseLayout.astro";
import BlurImage from "../components/BlurImage.astro";
import JsonLd from "../components/JsonLd.astro";
import TagList from "../components/TagList.astro";
import { blogPostingSchema } from "../lib/structured-data";
import { readingTime } from "../lib/reading-time";
import { inlineMarkdown } from "../lib/inlineMarkdown";
import type { CollectionEntry } from "astro:content";

interface Props {
    post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, date, description, tags, cover, coverAlt, coverCaption } =
    post.data;

const formattedDate = date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
const minutes = readingTime(post.body);

// Auto-generated from frontmatter (+ resolved URLs), so it stays accurate.
const schema = blogPostingSchema(
    post,
    new URL(`/blog/${post.id}/`, Astro.site).href,
    new URL(cover.src, Astro.site).href,
);
---

<!-- Per-post SEO: the cover doubles as the social share image. -->
<BaseLayout
    title={`${title} · streanga.com`}
    description={description}
    image={cover.src}
    type="article"
>
    <JsonLd schema={schema} />
    <main id="main" class="container post">
        <article>
            <header class="post-header">
                <p class="post-meta">
                    <time datetime={date.toISOString()}>{formattedDate}</time>
                    <span aria-hidden="true"> · </span>
                    {minutes} min read
                </p>
                <h1 class="post-title">{title}</h1>
                {
                    tags.length > 0 && (
                        <div class="post-tags">
                            <TagList tags={tags} />
                        </div>
                    )
                }
            </header>

            <figure class="post-cover">
                <BlurImage
                    src={cover}
                    alt={coverAlt || title}
                    sizes="(max-width: 56rem) 92vw, 56rem"
                    priority
                />
                {
                    coverCaption && (
                        <figcaption set:html={inlineMarkdown(coverCaption)} />
                    )
                }
            </figure>

            <div class="prose">
                <slot />
            </div>
        </article>
    </main>
</BaseLayout>

<style>
    .post {
        padding-block: var(--space-12) var(--space-24);
    }
    article {
        max-inline-size: 56rem;
        margin-inline: auto;
    }

    .post-header {
        margin-block-end: var(--space-8);
    }
    .post-meta {
        color: var(--color-text-muted);
        font-size: var(--text-sm);
    }
    .post-title {
        font-size: var(--text-4xl);
        margin-block-start: var(--space-2);
    }
    .post-tags {
        margin-block-start: var(--space-6);
    }

    .post-cover {
        margin: 0 0 var(--space-12);
    }
    /* Reach into BlurImage's wrapper to size and round the cover. */
    .post-cover :global(.blur-image) {
        inline-size: 100%;
        aspect-ratio: 16 / 9;
        border-radius: var(--radius-lg);
    }
    .post-cover figcaption {
        margin-block-start: var(--space-3);
        color: var(--color-text-muted);
        font-size: var(--text-sm);
        line-height: 1.5;
        text-align: center;
    }
    .post-cover figcaption :global(a) {
        color: var(--color-accent);
        text-decoration: underline;
    }

    /* ---- Prose: the shared reading style for rendered Markdown ---- */
    .prose {
        font-size: var(--text-lg);
    }

    .prose :global(p),
    .prose :global(h2),
    .prose :global(h3),
    .prose :global(ul),
    .prose :global(ol),
    .prose :global(blockquote),
    .prose :global(pre) {
        max-inline-size: 48rem;
        margin-inline: auto;
    }
    /* Markdown image-only paragraphs (![]()) span the full width too. */
    .prose :global(p:has(> img)) {
        max-inline-size: none;
    }
    .prose :global(p),
    .prose :global(ul),
    .prose :global(ol),
    .prose :global(blockquote),
    .prose :global(pre) {
        margin-block: var(--space-6);
    }

    .prose :global(h2) {
        font-size: var(--text-2xl);
        margin-block: var(--space-12) var(--space-4);
    }
    .prose :global(h3) {
        font-size: var(--text-lg);
        margin-block: var(--space-8) var(--space-3);
    }

    .prose :global(ul),
    .prose :global(ol) {
        padding-inline-start: var(--space-6);
    }
    .prose :global(li) {
        margin-block: var(--space-2);
    }

    .prose :global(a) {
        color: var(--color-accent);
        text-decoration: underline;
    }

    .prose :global(blockquote) {
        border-inline-start: 3px solid var(--color-brand);
        padding-inline-start: var(--space-6);
        color: var(--color-text-muted);
        font-style: italic;
    }

    .prose :global(code) {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.9em;
        background-color: var(--color-surface-sunken);
        padding: 0.15em 0.4em;
        border-radius: 4px;
    }
    .prose :global(a code) {
        color: var(--color-accent-strong);
    }
    .prose :global(pre) {
        background-color: var(--color-surface-sunken);
        padding: var(--space-4);
        border-radius: var(--radius);
        overflow-x: auto;
    }
    .prose :global(pre code) {
        background: none;
        padding: 0;
    }

    .prose :global(img) {
        border-radius: var(--radius);
        margin-block: var(--space-6);
    }
    .prose :global(hr) {
        border: 0;
        border-block-start: 1px solid var(--color-border);
        margin-block: var(--space-12);
    }

    /* ---- Tables: a card that echoes the code block's frame ---- */
    .prose :global(.table-wrap) {
        margin-block: var(--space-8);
        overflow-x: auto; /* wide tables scroll; the radius clips the corners */
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        background: var(--color-surface);
        box-shadow: var(--shadow);
    }
    .prose :global(.table-wrap table) {
        width: 100%;
        border-collapse: collapse;
        font-size: var(--text-sm);
        line-height: 1.5;
    }
    .prose :global(.table-wrap th),
    .prose :global(.table-wrap td) {
        padding: var(--space-3) var(--space-4);
        text-align: left;
        vertical-align: top;
    }
    /* Header strip: same sunken tone as the code block's title bar. */
    .prose :global(.table-wrap thead th) {
        background: var(--color-surface-sunken);
        font-weight: 600;
        letter-spacing: 0.01em;
        white-space: nowrap;
        border-block-end: 1px solid var(--color-border);
    }
    /* Hairline between rows + a quiet zebra stripe for scanning. */
    .prose :global(.table-wrap tbody tr + tr) {
        border-block-start: 1px solid var(--color-border);
    }
    .prose :global(.table-wrap tbody tr:nth-child(even)) {
        background: color-mix(
            in srgb,
            var(--color-surface-sunken) 45%,
            transparent
        );
    }
    /* First column reads as the row label. */
    .prose :global(.table-wrap td:first-child) {
        font-weight: 600;
    }
</style>
