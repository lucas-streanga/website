---
// Site footer: copyright, secondary nav, and social links. Rendered site-wide
// from BaseLayout. Link handles the external rel/target for the social icons.
import Link from "./Link.astro";
const year = new Date().getFullYear();
---

<footer class="site-footer">
    <div class="container footer-inner">
        <p class="copyright">© {year} Lucas Streanga</p>

        <nav class="footer-nav" aria-label="Footer">
            <a href="/blog">Blog</a>
            <a href="/privacy">Privacy</a>
            <a href="/rss.xml">RSS</a>
        </nav>

        <ul class="social">
            <li>
                <Link
                    href="https://github.com/lucas-streanga"
                    aria-label="GitHub (opens in a new tab)"
                >
                    <svg
                        class="icon"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <path
                            d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
                        ></path>
                    </svg>
                </Link>
            </li>
            <li>
                <Link
                    href="https://www.linkedin.com/in/lucas-streanga-1a16891ab/"
                    aria-label="LinkedIn (opens in a new tab)"
                >
                    <svg
                        class="icon"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <path
                            d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                        ></path>
                        <rect x="2" y="9" width="4" height="12"></rect>
                        <circle cx="4" cy="4" r="2"></circle>
                    </svg>
                </Link>
            </li>
            <li>
                <Link
                    href="https://www.instagram.com/lucas_streanga/"
                    aria-label="Instagram (opens in a new tab)"
                >
                    <svg
                        class="icon"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"
                        ></rect>
                        <path
                            d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                        ></path>
                        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                    </svg>
                </Link>
            </li>
        </ul>
    </div>
</footer>

<style>
    .site-footer {
        margin-block-start: var(--space-24);
        padding-block: var(--space-8);
        border-block-start: 1px solid var(--color-border);
    }
    .footer-inner {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-6);
    }
    .copyright {
        margin: 0;
        font-size: var(--text-sm);
        color: var(--color-text-muted);
    }
    .footer-nav {
        display: flex;
        gap: var(--space-6);
    }
    .footer-nav a {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        text-decoration: none;
    }
    .footer-nav a:hover {
        color: var(--color-text);
    }
    .social {
        display: flex;
        gap: var(--space-4);
        margin: 0;
        padding: 0;
        list-style: none;
    }
    /* The <a> is rendered by Link (its own scope), so reach it with :global. */
    .social :global(a) {
        display: inline-grid;
        place-items: center;
        color: var(--color-text-muted);
        transition: color 0.15s ease;
    }
    .social :global(a:hover) {
        color: var(--color-accent);
    }
    .icon {
        inline-size: 1.25rem;
        block-size: 1.25rem;
    }

    @media (max-width: 40rem) {
        .footer-inner {
            flex-direction: column;
            text-align: center;
        }
    }
</style>
