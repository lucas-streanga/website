---
// Renders a schema.org object as a JSON-LD <script>. Astro leaves
// application/ld+json scripts untouched (they aren't JS); the csp-headers hook
// hashes it automatically like any other inline script.
interface Props {
    schema: Record<string, unknown>;
}
const { schema } = Astro.props;
// Escape "<" so a stray "</script>" inside any string field can't break out of
// the tag (the standard JSON-LD injection guard).
const json = JSON.stringify(schema).replace(/</g, "\\u003c");
---

<script type="application/ld+json" set:html={json} />
