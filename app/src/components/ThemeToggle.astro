---

---

<button
    id="theme-toggle"
    type="button"
    class="theme-toggle"
    disabled
    aria-label="Current theme"
>
    <!-- Icon shows the current theme (sun = light, moon = dark) so it reads as
         an indicator; JS removes `disabled` to make it a real toggle. -->
    <svg
        class="icon icon-sun"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
    >
        <circle cx="12" cy="12" r="4"></circle>
        <path
            d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.5 1.5M17.5 17.5L19 19M19 5l-1.5 1.5M6.5 17.5L5 19"
        ></path>
    </svg>
    <svg
        class="icon icon-moon"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
    >
        <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
    </svg>
</button>

<style>
    .theme-toggle {
        display: inline-grid;
        place-items: center;
        inline-size: 2.5rem;
        block-size: 2.5rem;
        padding: 0;
        cursor: pointer;
        color: var(--color-text);
        background-color: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 999px;
        transition:
            background-color 0.15s ease,
            border-color 0.15s ease;
    }
    /* Inert indicator until JS enables it (see the `disabled` attr + script). */
    .theme-toggle:disabled {
        cursor: default;
        opacity: 1;
    }
    .theme-toggle:not(:disabled):hover {
        border-color: var(--color-accent);
    }
    .icon {
        inline-size: 1.15rem;
        block-size: 1.15rem;
    }

    .icon-moon {
        display: none;
    }
    :global(html[data-theme="dark"]) .icon-sun {
        display: none;
    }
    :global(html[data-theme="dark"]) .icon-moon {
        display: block;
    }
    /* No explicit choice yet → the page follows the OS, so the icon must too. */
    @media (prefers-color-scheme: dark) {
        :global(html:not([data-theme])) .icon-sun {
            display: none;
        }
        :global(html:not([data-theme])) .icon-moon {
            display: block;
        }
    }
</style>

<script>
    const root = document.documentElement;
    const toggle = document.getElementById("theme-toggle");
    const mql = window.matchMedia("(prefers-color-scheme: dark)");

    // The theme actually shown: an explicit choice if set, else the OS
    // preference (the unset/CSS-driven state).
    function effectiveTheme() {
        if (root.dataset.theme === "dark" || root.dataset.theme === "light") {
            return root.dataset.theme;
        }
        return mql.matches ? "dark" : "light";
    }

    // Update only the button's accessible state — no storage writes.
    function syncButton(theme: string) {
        const dark = theme === "dark";
        toggle?.setAttribute(
            "aria-label",
            dark ? "Switch to light mode" : "Switch to dark mode",
        );
        toggle?.setAttribute("aria-pressed", String(dark));
    }

    // Pin an explicit choice (only from a real click). Also sets inline
    // color-scheme to match the head script — otherwise a stale inline value
    // would override the CSS on the next toggle.
    function setTheme(theme: string) {
        root.dataset.theme = theme;
        root.style.colorScheme = theme;
        localStorage.setItem("theme", theme);
        syncButton(theme);
    }

    syncButton(effectiveTheme());

    // Enable the control now that JS can handle clicks (inert without JS).
    toggle?.removeAttribute("disabled");

    toggle?.addEventListener("click", () => {
        setTheme(effectiveTheme() === "dark" ? "light" : "dark");
    });

    // If the visitor never toggled, follow live OS changes and keep the label
    // honest; once they've chosen, their choice stands.
    mql.addEventListener("change", () => {
        if (!root.dataset.theme) syncButton(effectiveTheme());
    });
</script>
