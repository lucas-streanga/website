---
import { Image } from "astro:assets";
import sharp from "sharp";
import type { ImageMetadata } from "astro";

interface Props {
    src: ImageMetadata;
    alt: string;
    width?: number;
    height?: number;
    priority?: boolean;
    class?: string;
    sizes?: string;
    widths?: number[];
}

const {
    src,
    alt,
    width,
    height,
    priority = false,
    class: className,
    sizes,
    widths,
} = Astro.props;

// Build a responsive srcset by default so callers needn't pass `widths`.
// Candidates are capped at the source's real width (Astro never upscales);
// an explicit `widths` prop is respected as-is.
const CANDIDATE_WIDTHS = [360, 640, 828, 1080, 1600];
const maxWidth = src.width;
const responsiveWidths =
    widths && widths.length
        ? widths
        : [
              ...new Set([
                  ...CANDIDATE_WIDTHS.filter((w) => w < maxWidth),
                  maxWidth,
              ]),
          ].sort((a, b) => a - b);
// A srcset needs a companion `sizes`; fall back to full-width so the two are
// never mismatched (callers should pass a real `sizes` for best results).
const responsiveSizes = sizes ?? "100vw";

// Build the blur-up placeholder at build time, but ONLY for opaque images:
// with real transparency (transparent PNG/SVG) the blurred copy shows through
// the transparent areas as a halo, so we skip it and render a plain image instead.
let placeholder = "";
try {
    const fsPath = (src as ImageMetadata & { fsPath: string }).fsPath;
    const { isOpaque } = await sharp(fsPath).stats();
    if (isOpaque) {
        const buf = await sharp(fsPath)
            .resize(24, 24, { fit: "inside" })
            .blur()
            .webp({ quality: 40 })
            .toBuffer();
        placeholder = `data:image/webp;base64,${buf.toString("base64")}`;
    }
} catch {
    // Detection/generation failed → no placeholder; the image still renders, just without the blur-up.
    placeholder = "";
}
---

<div
    class:list={["blur-image", className]}
    style={placeholder
        ? `background-image:url("${placeholder}");background-size:cover;background-position:center;background-repeat:no-repeat;`
        : undefined}
>
    <Image
        src={src}
        alt={alt}
        width={width}
        height={height}
        sizes={responsiveSizes}
        widths={responsiveWidths}
        priority={priority}
    />
    <script is:inline>
        // Runs before paint: if the image is already loaded (cached), leave it
        // visible with no fade; only hide + fade-in when it's still pending.
        (function () {
            var s = document.currentScript;
            var wrap = s && s.closest(".blur-image");
            var img = wrap && wrap.querySelector("img");
            if (!img || img.complete) return;
            wrap.classList.add("is-loading");
            img.addEventListener(
                "load",
                function () {
                    wrap.classList.add("is-loaded");
                },
                { once: true },
            );
        })();
    </script>
</div>

<style>
    .blur-image {
        display: block;
        overflow: hidden; /* clips the inner image to the wrapper's radius */
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }
    /* Fill and cover the wrapper so the decoded photo hides the blur underneath.
     Default is fully visible — so a no-JS visitor and any already-loaded (cached)
     image show instantly with no fade. */
    .blur-image :global(img) {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: opacity 0.5s ease;
    }
    /* Script adds .is-loading only while the image is pending, then .is-loaded
     on load — cross-fading it in over the blur. */
    .blur-image.is-loading :global(img) {
        opacity: 0;
    }
    .blur-image.is-loading.is-loaded :global(img) {
        opacity: 1;
    }
</style>
