---
// BlurImage.astro
// Astro's optimized <Image> plus a build-time "blur-up" placeholder.
//
// A tiny blurred copy of the source is generated with sharp at build time and
// inlined as a data URI on the wrapper's background — so it shows instantly
// with the HTML (no extra request, no JS). When the real image decodes it
// paints over the blur. Pass `priority` for above-the-fold images (hero,
// post cover) so they load eagerly instead of Astro's lazy default.
//
// Requires the image to be imported from src/ (e.g. src/assets/…), not public/,
// so Astro can process it and expose fsPath.
import { Image } from "astro:assets";
import sharp from "sharp";
import type { ImageMetadata } from "astro";

interface Props {
    src: ImageMetadata;
    alt: string;
    width?: number;
    height?: number;
    priority?: boolean;
    class?: string;
    sizes?: string;
    widths?: number[];
}

const {
    src,
    alt,
    width,
    height,
    priority = false,
    class: className,
    sizes,
    widths,
} = Astro.props;

// Generate the low-quality placeholder once, at build time.
let placeholder = "";
try {
    const buf = await sharp((src as ImageMetadata & { fsPath: string }).fsPath)
        .resize(24, 24, { fit: "inside" })
        .blur()
        .webp({ quality: 40 })
        .toBuffer();
    placeholder = `data:image/webp;base64,${buf.toString("base64")}`;
} catch {
    // If generation fails, fall back to no placeholder — the image still renders.
    placeholder = "";
}
---

<div
    class:list={["blur-image", className]}
    style={placeholder ? `background-image:url("${placeholder}");` : undefined}
>
    <Image
        src={src}
        alt={alt}
        width={width}
        height={height}
        sizes={sizes}
        widths={widths}
        priority={priority}
    />
    <script is:inline>
        // Runs synchronously, before paint. If the image is already loaded
        // (cached / instant), do nothing — it stays visible with no fade.
        // Only when it's still pending do we hide it and fade it in on load.
        (function () {
            var s = document.currentScript;
            var wrap = s && s.closest(".blur-image");
            var img = wrap && wrap.querySelector("img");
            if (!img || img.complete) return;
            wrap.classList.add("is-loading");
            img.addEventListener(
                "load",
                function () {
                    wrap.classList.add("is-loaded");
                },
                { once: true },
            );
        })();
    </script>
</div>

<style>
    .blur-image {
        display: block;
        overflow: hidden; /* clips the inner image to the wrapper's radius */
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }
    /* The Image renders its own <img>; make it fill and cover the wrapper so the
     decoded (opaque) photo hides the blur underneath it. Default is fully
     visible — so a no-JS visitor and any already-loaded (cached) image show
     instantly with no fade. */
    .blur-image :global(img) {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: opacity 0.5s ease;
    }
    /* The inline script adds .is-loading only when the image is still pending;
     it then adds .is-loaded on load, which cross-fades it in over the blur. */
    .blur-image.is-loading :global(img) {
        opacity: 0;
    }
    .blur-image.is-loading.is-loaded :global(img) {
        opacity: 1;
    }
</style>
