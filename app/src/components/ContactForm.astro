---
// Contact form for the home page; posts to the /api/contact Pages Function.
// Progressive enhancement: without JS the form posts natively and redirects to
// /contact/thanks; with JS the submit is intercepted and an inline panel
// replaces the form.
const MAX_MESSAGE = 1024;
---

<div class="contact-grid">
    <div class="contact-intro">
        <p class="eyebrow">Contact</p>
        <h2 class="contact-title">Get in touch</h2>
        <p class="contact-lead">
            Have a question, an idea, or just want to say hi? Send a message and
            it lands straight in my inbox.
        </p>
        <p class="contact-alt">
            Prefer email? <a href="mailto:contactform@streanga.com"
                >contactform@streanga.com</a
            >
        </p>
    </div>

    <div class="form-card">
        <form
            id="contact-form"
            class="form"
            method="POST"
            action="/api/contact"
        >
            <div class="field">
                <label for="cf-email"
                    >Email <span class="req" aria-hidden="true">*</span></label
                >
                <input
                    type="email"
                    id="cf-email"
                    name="email"
                    required
                    autocomplete="email"
                    placeholder="you@example.com"
                />
            </div>

            <div class="field">
                <label for="cf-name"
                    >Name <span class="optional">(optional)</span></label
                >
                <input
                    type="text"
                    id="cf-name"
                    name="name"
                    maxlength="256"
                    autocomplete="name"
                    placeholder="Ada Lovelace"
                />
            </div>

            <div class="field">
                <div class="field-head">
                    <label for="cf-message"
                        >Message <span class="req" aria-hidden="true">*</span
                        ></label
                    >
                    <span class="counter" data-counter aria-hidden="true"
                    ></span>
                </div>
                <textarea
                    id="cf-message"
                    name="message"
                    required
                    rows="5"
                    maxlength={MAX_MESSAGE}
                    placeholder="What's on your mind?"></textarea>
            </div>

            {
                /* Honeypot: hidden from humans + AT but still submitted; the server drops it if non-empty. */
            }
            <div class="hp" aria-hidden="true">
                <label for="cf-website">Website</label>
                <input
                    type="text"
                    id="cf-website"
                    name="website"
                    tabindex="-1"
                    autocomplete="off"
                />
            </div>

            <button type="submit" class="btn btn-primary" data-submit
                >Send message</button
            >

            <p class="form-status" data-status role="status" aria-live="polite">
            </p>
        </form>

        {/* Sibling of the form so the script can swap it in on success. */}
        <div
            class="form-success"
            data-success
            role="status"
            aria-live="polite"
            hidden
        >
            <h3>Thanks — your message is on its way.</h3>
            <p>I read every message and will reply to the email you gave me.</p>
        </div>
    </div>
</div>

<style>
    .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1.1fr;
        gap: clamp(var(--space-8), 5vw, var(--space-12));
        align-items: start;
    }

    .eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--color-accent);
        margin-block-end: var(--space-4);
    }
    .contact-title {
        font-size: var(--text-2xl);
    }
    .contact-lead {
        margin-block-start: var(--space-4);
        max-inline-size: 42ch;
        color: var(--color-text-muted);
    }
    .contact-alt {
        margin-block-start: var(--space-6);
        font-size: var(--text-sm);
        color: var(--color-text-muted);
    }

    .form-card {
        padding: clamp(var(--space-6), 4vw, var(--space-8));
        background-color: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
    }

    .form {
        display: grid;
        gap: var(--space-6);
    }
    /* Explicit display beats the UA [hidden]{display:none}; without this the
       form won't hide on success. */
    .form[hidden] {
        display: none;
    }
    .field {
        display: grid;
        gap: var(--space-2);
    }
    label {
        font-size: var(--text-sm);
        font-weight: 600;
    }
    .optional {
        font-weight: 400;
        color: var(--color-text-muted);
    }
    .req {
        color: var(--color-accent);
    }

    input,
    textarea {
        inline-size: 100%;
        padding: var(--space-3) var(--space-4);
        color: var(--color-text);
        background-color: var(--color-surface-sunken);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        transition: border-color 0.15s ease;
    }
    input::placeholder,
    textarea::placeholder {
        color: var(--color-text-muted);
        opacity: 0.7;
    }
    /* Global :focus-visible still adds the keyboard ring on top of this. */
    input:focus,
    textarea:focus {
        border-color: var(--color-accent);
    }
    textarea {
        resize: vertical;
        min-block-size: 7rem;
    }

    .field-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: var(--space-4);
    }
    /* On the label row (empty until JS fills it) so appearing adds no height —
       otherwise it shoves the Send button down on load (a layout shift). */
    .counter {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
    }
    .counter[data-near="true"] {
        color: var(--color-accent);
    }

    button[data-submit] {
        justify-self: start;
    }

    .form-status {
        margin: 0;
        font-size: var(--text-sm);
    }
    .form-status:empty {
        display: none;
    }
    .form-status[data-state="error"] {
        color: var(--color-accent-strong);
    }

    .form-success h3 {
        font-size: var(--text-lg);
    }
    .form-success p {
        margin-block-start: var(--space-3);
        color: var(--color-text-muted);
    }

    /* Off-screen, not display:none — some bots skip hidden fields but fill positioned ones. */
    .hp {
        position: absolute;
        left: -9999px;
        width: 1px;
        height: 1px;
        overflow: hidden;
    }

    @media (max-width: 48rem) {
        .contact-grid {
            grid-template-columns: 1fr;
            gap: var(--space-8);
        }
    }
</style>

<script>
    const MAX_MESSAGE = 1024;

    function initContactForm() {
        const form = document.getElementById(
            "contact-form",
        ) as HTMLFormElement | null;
        // Guard against double-init: astro:page-load can re-fire for the same DOM.
        if (!form || form.dataset.enhanced === "true") return;
        form.dataset.enhanced = "true";

        const message =
            form.querySelector<HTMLTextAreaElement>("[name='message']");
        const counter = form.querySelector<HTMLElement>("[data-counter]");
        const submit = form.querySelector<HTMLButtonElement>("[data-submit]");
        const status = form.querySelector<HTMLElement>("[data-status]");
        const success =
            form.parentElement?.querySelector<HTMLElement>("[data-success]");

        // JS-only nicety; maxlength still caps the field without it.
        if (message && counter) {
            const update = () => {
                const len = message.value.length;
                counter.textContent = `${len} / ${MAX_MESSAGE}`;
                counter.dataset.near = String(len >= MAX_MESSAGE * 0.9);
            };
            update();
            message.addEventListener("input", update);
        }

        const setStatus = (text: string, state?: "error") => {
            if (!status) return;
            status.textContent = text;
            if (state) status.dataset.state = state;
            else delete status.dataset.state;
        };

        form.addEventListener("submit", async (event) => {
            // Native validation already passed — submit doesn't fire otherwise.
            event.preventDefault();
            if (!submit) return;

            setStatus("");
            const label = submit.textContent;
            submit.disabled = true;
            submit.textContent = "Sending…";

            try {
                const res = await fetch(form.action, {
                    method: "POST",
                    headers: { Accept: "application/json" },
                    body: new URLSearchParams(
                        new FormData(form) as unknown as Record<string, string>,
                    ),
                });
                const data = await res.json().catch(() => ({}));

                if (res.ok && data.ok) {
                    form.hidden = true;
                    if (success) {
                        success.hidden = false;
                        success.setAttribute("tabindex", "-1");
                        success.focus();
                    }
                    return;
                }

                setStatus(
                    data.error ||
                        "Something went wrong. Please email contactform@streanga.com directly.",
                    "error",
                );
            } catch {
                setStatus(
                    "Couldn't reach the server. Please email contactform@streanga.com directly.",
                    "error",
                );
            } finally {
                submit.disabled = false;
                submit.textContent = label;
            }
        });
    }

    // Runs on initial load and after each view transition.
    document.addEventListener("astro:page-load", initContactForm);
</script>
