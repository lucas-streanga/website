---
interface Props {
    href: string;
    newTab?: boolean;
    class?: string;
}

const { href, newTab, class: className, ...rest } = Astro.props;

// Only absolute http(s) URLs can be "external"; if a site origin is configured,
// same-origin links are treated as internal.
let isExternal = false;
if (/^https?:\/\//i.test(href)) {
    try {
        const url = new URL(href);
        isExternal = Astro.site ? url.origin !== Astro.site.origin : true;
    } catch {
        isExternal = false;
    }
}

const openNew = newTab ?? isExternal;
---

<a
    href={href}
    target={openNew ? "_blank" : undefined}
    rel={openNew ? "noopener noreferrer" : undefined}
    class={className}
    {...rest}
>
    <slot />
</a>
