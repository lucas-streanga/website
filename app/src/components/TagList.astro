---
// Renders tags as pills linking to their tag pages. Shared by post cards, the
// post header, and anywhere else tags appear, so the pill style lives once.
import { tagSlug } from "../lib/tags";

interface Props {
    tags: string[];
}
const { tags } = Astro.props;
---

<ul class="tag-list">
    {
        tags.map((tag) => (
            <li>
                <a href={`/blog/tags/${tagSlug(tag)}/`} class="tag">
                    {tag}
                </a>
            </li>
        ))
    }
</ul>

<style>
    .tag-list {
        display: flex;
        flex-wrap: wrap;
        /* Larger row gap so wrapped pill rows don't crowd; tighter column gap. */
        gap: var(--space-3) var(--space-2);
        margin: 0;
        padding: 0;
        list-style: none;
    }
    .tag {
        display: inline-block;
        font-size: var(--text-sm);
        line-height: 1.4;
        /* accent-strong, not accent: accent is tuned against --color-bg, and the
         sunken pill shifts the backdrop the wrong way in both modes, landing
         under 4.5:1. */
        color: var(--color-accent-strong);
        background-color: var(--color-surface-sunken);
        padding: 0.3rem 0.7rem;
        border-radius: 999px;
        text-decoration: none;
        transition:
            background-color 0.15s ease,
            color 0.15s ease;
    }
    .tag:hover {
        background-color: var(--color-accent);
        color: var(--color-accent-contrast);
    }
</style>
