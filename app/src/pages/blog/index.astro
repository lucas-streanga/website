---
// /blog — the post index, newest first, as cards.
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<BaseLayout
    title="Blog — streanga.com"
    description="Writing by Lucas on building things."
>
    <main id="main" class="container blog-index">
        <header class="blog-head">
            <h1>Blog</h1>
            <p class="lead">
                Notes on building things. <a href="/blog/tags"
                    >Browse by tag →</a
                >
            </p>
        </header>

        <ul class="card-grid">
            {posts.map((post) => <PostCard post={post} />)}
        </ul>
    </main>
</BaseLayout>

<style>
    .blog-index {
        padding-block: var(--space-12) var(--space-24);
    }
    .blog-head {
        margin-block-end: var(--space-12);
    }
    .blog-head h1 {
        font-size: var(--text-4xl);
    }
    .lead {
        margin-block-start: var(--space-3);
        color: var(--color-text-muted);
        font-size: var(--text-lg);
    }
    .lead a {
        color: var(--color-accent);
        white-space: nowrap;
    }

    .card-grid {
        list-style: none;
        padding: 0;
        display: grid;
        gap: var(--space-8);
        grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 1fr));
    }
</style>
