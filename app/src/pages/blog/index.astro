---
// /blog — the post index, newest first, as cards.
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlurImage from "../../components/BlurImage.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<BaseLayout
    title="Blog — streanga.com"
    description="Writing by Lucas on building things."
>
    <main id="main" class="container blog-index">
        <header class="blog-head">
            <h1>Blog</h1>
            <p class="lead">Notes on building things.</p>
        </header>

        <ul class="card-grid">
            {
                posts.map((post: any) => {
                    const dateStr = post.data.date.toLocaleDateString("en-US", {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                    });
                    return (
                        <li class="card">
                            <a href={`/blog/${post.id}`} class="card-link">
                                <BlurImage
                                    src={post.data.cover}
                                    alt={post.data.coverAlt || post.data.title}
                                    class="card-cover"
                                />
                                <div class="card-body">
                                    <p class="card-date">
                                        <time
                                            datetime={post.data.date.toISOString()}
                                        >
                                            {dateStr}
                                        </time>
                                    </p>
                                    <h2 class="card-title">
                                        {post.data.title}
                                    </h2>
                                    <p class="card-desc">
                                        {post.data.description}
                                    </p>
                                    {post.data.tags.length > 0 && (
                                        <ul class="tags">
                                            {post.data.tags.map(
                                                (tag: string) => (
                                                    <li class="tag">{tag}</li>
                                                ),
                                            )}
                                        </ul>
                                    )}
                                </div>
                            </a>
                        </li>
                    );
                })
            }
        </ul>
    </main>
</BaseLayout>

<style>
    .blog-index {
        padding-block: var(--space-12) var(--space-24);
    }
    .blog-head {
        margin-block-end: var(--space-12);
    }
    .blog-head h1 {
        font-size: var(--text-4xl);
    }
    .lead {
        margin-block-start: var(--space-3);
        color: var(--color-text-muted);
        font-size: var(--text-lg);
    }

    .card-grid {
        list-style: none;
        padding: 0;
        display: grid;
        gap: var(--space-8);
        grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 1fr));
    }

    .card {
        background-color: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        transition:
            transform 0.15s ease,
            border-color 0.15s ease;
    }
    .card:hover {
        transform: translateY(-3px);
        border-color: var(--color-brand);
    }

    .card-link {
        display: block;
        color: inherit;
        text-decoration: none;
    }
    .card-cover {
        display: block;
        inline-size: 100%;
        aspect-ratio: 16 / 9;
    }
    .card-body {
        padding: var(--space-6);
    }
    .card-date {
        color: var(--color-text-muted);
        font-size: var(--text-sm);
    }
    .card-title {
        font-size: var(--text-lg);
        margin-block: var(--space-2);
    }
    .card-desc {
        color: var(--color-text-muted);
        font-size: var(--text-base);
    }

    .tags {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2);
        margin-block-start: var(--space-4);
        padding: 0;
    }
    .tag {
        font-size: var(--text-sm);
        color: var(--color-accent);
        background-color: var(--color-surface-sunken);
        padding: 0.15rem 0.6rem;
        border-radius: 999px;
    }
</style>
