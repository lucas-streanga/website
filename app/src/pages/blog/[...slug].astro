---
// Markdown in a collection is no longer auto-routed, so this file generates one
// page per blog entry — turning each post into /blog/<id>.
import { getCollection, render } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";
// Provided to <Content> so ```luna fences (rewritten to <LunaCode> by the
// remark-luna-fences plugin) resolve without a per-post import.
import LunaCode from "../../components/LunaCode.astro";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts.map((post: any) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<PostLayout post={post}>
    <Content components={{ LunaCode }} />
</PostLayout>
