---
// Colors/spacing all come from the tokens in styles/global.css.
import BaseLayout from "../layouts/BaseLayout.astro";
import BlurImage from "../components/BlurImage.astro";
import ContactForm from "../components/ContactForm.astro";
import JsonLd from "../components/JsonLd.astro";
import { personSchema } from "../lib/structured-data";
import { readingTime } from "../lib/reading-time";
import { getCollection } from "astro:content";
import me from "../assets/me.jpg";

const person = personSchema(new URL(me.src, Astro.site).href);

const latest = (await getCollection("blog")).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
)[0];
const latestDate = latest.data.date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
});
const latestMinutes = readingTime(latest.body);
---

<BaseLayout title="Lucas · Home" description="Personal site of Lucas.">
    <JsonLd schema={person} />
    <main id="main">
        <section class="hero">
            <div class="container hero-grid">
                <div class="hero-text">
                    <p class="eyebrow">Developer</p>
                    <h1 class="hero-title">Hi, I'm Lucas.</h1>
                    <p class="hero-lead">
                        I'm a software engineer at Paycom who loves everything
                        about computers and software. I'm especially tickled by
                        programming languages, from their design to their
                        implementation.
                    </p>
                    <div class="actions">
                        <a href="/blog" class="btn btn-primary">Read the blog</a
                        >
                        <a href="/about" class="btn btn-ghost">More about me</a>
                    </div>
                </div>

                <div class="hero-media">
                    <BlurImage
                        src={me}
                        alt="Lucas"
                        width={320}
                        height={320}
                        sizes="(max-width: 48rem) 220px, 320px"
                        widths={[360, 640, 1080]}
                        priority
                        class="photo"
                    />
                </div>
            </div>
        </section>

        <section class="latest">
            <div class="container">
                <div class="latest-head">
                    <h2>Latest post</h2>
                    <a href="/blog" class="all-link">All posts →</a>
                </div>

                <a href={`/blog/${latest.id}`} class="feature">
                    <BlurImage
                        src={latest.data.cover}
                        alt={latest.data.coverAlt || latest.data.title}
                        sizes="(max-width: 48rem) 92vw, 20rem"
                        class="feature-cover"
                    />
                    <div class="feature-body">
                        <p class="feature-meta">
                            <time datetime={latest.data.date.toISOString()}
                                >{latestDate}</time
                            >
                            <span aria-hidden="true"> · </span>
                            {latestMinutes} min read
                        </p>
                        <h3 class="feature-title">{latest.data.title}</h3>
                        <p class="feature-desc">{latest.data.description}</p>
                        <span class="feature-more">Read the post →</span>
                    </div>
                </a>
            </div>
        </section>

        <section id="contact" class="contact">
            <div class="container">
                <ContactForm />
            </div>
        </section>
    </main>
</BaseLayout>

<style>
    .hero {
        padding-block: clamp(var(--space-16), 8vw, var(--space-24));
    }
    .contact {
        position: relative;
        padding-block: clamp(var(--space-12), 6vw, var(--space-16))
            clamp(var(--space-16), 8vw, var(--space-24));
    }
    /* Fading hairline as a soft seam above the section, instead of a hard rule. */
    .contact::before {
        content: "";
        position: absolute;
        inset-block-start: 0;
        inset-inline: 0;
        margin-inline: auto;
        inline-size: min(100% - 2 * var(--space-6), var(--container));
        block-size: 1px;
        background: linear-gradient(
            90deg,
            transparent,
            var(--color-border),
            transparent
        );
    }
    .hero-grid {
        display: grid;
        gap: var(--space-12);
        align-items: center;
        grid-template-columns: 1.2fr 0.8fr;
    }
    .eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--color-accent);
        margin-block-end: var(--space-4);
    }
    .hero-title {
        font-size: var(--text-4xl);
    }
    .hero-lead {
        margin-block-start: var(--space-6);
        max-inline-size: 46ch;
        font-size: var(--text-lg);
        color: var(--color-text-muted);
    }
    .actions {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-4);
        margin-block-start: var(--space-8);
    }

    .hero-media :global(.photo) {
        inline-size: 100%;
        max-inline-size: 320px;
        aspect-ratio: 1;
        border-radius: var(--radius-lg);
        margin-inline: auto;
    }

    /* --- Latest post --- */
    .latest {
        padding-block-end: clamp(var(--space-16), 8vw, var(--space-24));
    }
    .latest-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: var(--space-4);
        margin-block-end: var(--space-6);
    }
    .latest-head h2 {
        font-size: var(--text-2xl);
    }
    .all-link {
        color: var(--color-accent);
        font-size: var(--text-sm);
        white-space: nowrap;
    }

    .feature {
        display: grid;
        grid-template-columns: minmax(0, 20rem) 1fr;
        background-color: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        transition:
            border-color 0.15s ease,
            transform 0.15s ease;
    }
    .feature:hover {
        border-color: var(--color-brand);
        transform: translateY(-3px);
    }
    /* Cover fills its column; card height is driven by the body (min 13rem). */
    .feature-cover {
        block-size: 100%;
        min-block-size: 13rem;
    }
    .feature-body {
        padding: var(--space-8);
    }
    .feature-meta {
        color: var(--color-text-muted);
        font-size: var(--text-sm);
    }
    .feature-title {
        font-size: var(--text-2xl);
        margin-block: var(--space-2) var(--space-3);
    }
    .feature-desc {
        color: var(--color-text-muted);
    }
    .feature-more {
        display: inline-block;
        margin-block-start: var(--space-4);
        color: var(--color-accent);
        font-weight: 600;
        font-size: var(--text-sm);
    }

    /* Stack on narrow screens; photo first so it doesn't get pushed off-screen. */
    @media (max-width: 48rem) {
        .hero-grid {
            grid-template-columns: 1fr;
        }
        .hero-media {
            order: -1;
        }
        .photo {
            max-inline-size: 220px;
        }
        .feature {
            grid-template-columns: 1fr;
        }
        .feature-cover {
            block-size: auto;
            min-block-size: 0;
            aspect-ratio: 16 / 9;
        }
    }
</style>
