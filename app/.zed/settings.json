{
  // Treat .mdx blog posts as Markdown so the Harper grammar/spell
  // checker (which binds to Markdown, not MDX) attaches to them.
  "file_types": {
    "Markdown": ["mdx"]
  },
  "languages": {
    "Markdown": {
      // Harper is the checker; keep it on for Markdown/MDX.
      "language_servers": ["harper-ls"]
    }
  },
  "lsp": {
    "harper-ls": {
      "settings": {
        // Both nested "harper-ls" layers are required by the extension.
        "harper-ls": {
          "dialect": "American",
          // Project-local word list. Use the "Add to dictionary" code
          // action on a flagged word (e.g. Luna, LunaCode, argv) to
          // append here instead of polluting your global dictionary.
          "workspaceDictPath": ".harper-dictionary.txt"
        }
      }
    },
    // NOTE: the current Zed astro extension IGNORES this — it resolves TypeScript from
    // its OWN work dir (~/.local/share/zed/extensions/work/astro/node_modules) and never
    // reads typescript.tsdk. The fix that actually works is the symlink added to
    // sync_astro_editor.sh, which points that work dir at our synced app/node_modules/
    // typescript. Kept here only in case a future extension version honors tsdk (harmless).
    "astro-language-server": {
      "initialization_options": {
        "typescript": {
          "tsdk": "/home/lucas/projects/website/app/node_modules/typescript/lib"
        }
      }
    }
  }
}
